<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Compose owns real theming; this is just the launch/system theme. -->
    <style name="Theme.callNest" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">#E8E8EC</item>
        <item name="android:navigationBarColor">#E8E8EC</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:windowBackground">@drawable/ic_launcher_background</item>
    </style>

    <!-- Phase C — system splash theme; hands off to Theme.callNest after 200ms. -->
    <style name="Theme.callNest.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FF3D5A4A</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="windowSplashScreenAnimationDuration">200</item>
        <item name="postSplashScreenTheme">@style/Theme.callNest</item>
    </style>
</resources>
